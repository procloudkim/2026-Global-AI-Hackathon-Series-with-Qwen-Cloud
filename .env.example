# Qwen Cloud (DashScope International) API
DASHSCOPE_API_KEY=sk-your-key-here
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LIBRARIAN_LIGHT_MODEL=qwen-flash
LIBRARIAN_HEAVY_MODEL=qwen-plus-2025-07-28
LIBRARIAN_QWEN_TIMEOUT_SECONDS=30
LIBRARIAN_QWEN_MAX_RETRIES=0
LIBRARIAN_QWEN_MAX_COMPLETION_TOKENS=1600
LIBRARIAN_MEMORY_ROOT=memory
LIBRARIAN_DEPLOYED_SHA=unknown
LIBRARIAN_QWEN_HEALTH_TOKEN=replace-with-a-random-release-check-token
LIBRARIAN_RATE_LIMIT_PER_MINUTE=60
