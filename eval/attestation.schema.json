{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://librarian.example/schemas/private-holdout-attestation-v2.json",
  "title": "Librarian independent private holdout promotion attestation v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "created_at",
    "attestor",
    "candidate",
    "artifacts",
    "boundary",
    "aggregate",
    "live_qwen",
    "decision",
    "signature"
  ],
  "properties": {
    "schema_version": {"const": "2.0"},
    "kind": {"const": "librarian.private-holdout-promotion-attestation"},
    "created_at": {"type": "string", "format": "date-time"},
    "attestor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity",
        "independent_evaluator",
        "implementation_owner",
        "case_author",
        "signature_key_id"
      ],
      "properties": {
        "identity": {"type": "string", "minLength": 1},
        "independent_evaluator": {"const": true},
        "implementation_owner": {"const": false},
        "case_author": {"const": false},
        "signature_key_id": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evaluated_git_sha",
        "deployed_git_sha",
        "tree_sha256",
        "b2_implementation_sha256",
        "c_implementation_sha256",
        "answer_contract_sha256",
        "qwen_model_id",
        "qwen_prompt_sha256",
        "top_k",
        "context_budget"
      ],
      "properties": {
        "evaluated_git_sha": {"$ref": "#/$defs/gitSha"},
        "deployed_git_sha": {"$ref": "#/$defs/gitSha"},
        "tree_sha256": {"$ref": "#/$defs/sha256"},
        "b2_implementation_sha256": {"$ref": "#/$defs/sha256"},
        "c_implementation_sha256": {"$ref": "#/$defs/sha256"},
        "answer_contract_sha256": {"$ref": "#/$defs/sha256"},
        "qwen_model_id": {"type": "string", "minLength": 1},
        "qwen_prompt_sha256": {"$ref": "#/$defs/sha256"},
        "top_k": {"const": 3},
        "context_budget": {"const": 4000}
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_sha256",
        "protocol_sha256",
        "annotation_guide_sha256",
        "role_separation_manifest_sha256",
        "dataset_manifest_sha256",
        "runner_inputs_sha256",
        "paired_results_sha256",
        "aggregate_metrics_sha256",
        "raw_provider_responses_sha256",
        "usage_receipt_sha256",
        "bootstrap_samples_sha256"
      ],
      "properties": {
        "policy_sha256": {"$ref": "#/$defs/sha256"},
        "protocol_sha256": {"$ref": "#/$defs/sha256"},
        "annotation_guide_sha256": {"$ref": "#/$defs/sha256"},
        "role_separation_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "dataset_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "runner_inputs_sha256": {"$ref": "#/$defs/sha256"},
        "paired_results_sha256": {"$ref": "#/$defs/sha256"},
        "aggregate_metrics_sha256": {"$ref": "#/$defs/sha256"},
        "raw_provider_responses_sha256": {"$ref": "#/$defs/sha256"},
        "usage_receipt_sha256": {"$ref": "#/$defs/sha256"},
        "bootstrap_samples_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "split",
        "scenario_count",
        "analysis_unit",
        "collection_provenance",
        "author_pools_separate",
        "authors_separate_from_candidate_team",
        "gold_double_annotated",
        "third_party_adjudication",
        "final_candidate_outputs_hidden_during_collection",
        "intermediate_results_withheld_until_completion",
        "runner_process_isolated_from_oracle",
        "candidate_process_isolated_from_oracle",
        "evaluator_process_separate_from_runner",
        "oracle_generator",
        "oracle_uses_qwen",
        "pass_fail_judge",
        "judge_uses_qwen",
        "private_material_published",
        "repeat_semantics"
      ],
      "properties": {
        "split": {"const": "external_private_holdout"},
        "scenario_count": {"const": 384},
        "analysis_unit": {"const": "scenario"},
        "collection_provenance": {"const": "external_independent_v1"},
        "author_pools_separate": {"type": "boolean"},
        "authors_separate_from_candidate_team": {"type": "boolean"},
        "gold_double_annotated": {"type": "boolean"},
        "third_party_adjudication": {"type": "boolean"},
        "final_candidate_outputs_hidden_during_collection": {"type": "boolean"},
        "intermediate_results_withheld_until_completion": {"type": "boolean"},
        "runner_process_isolated_from_oracle": {"type": "boolean"},
        "candidate_process_isolated_from_oracle": {"type": "boolean"},
        "evaluator_process_separate_from_runner": {"type": "boolean"},
        "oracle_generator": {"const": "independent-human-adjudication-v1"},
        "oracle_uses_qwen": {"const": false},
        "pass_fail_judge": {
          "const": "deterministic-private-promotion-scorer-v2"
        },
        "judge_uses_qwen": {"const": false},
        "private_material_published": {"const": false},
        "repeat_semantics": {
          "const": "reproducibility_only_not_independent_samples"
        }
      }
    },
    "aggregate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "analysis_unit",
        "scenario_count",
        "pair_table",
        "statistics",
        "metrics",
        "pools",
        "cells"
      ],
      "properties": {
        "schema_version": {"const": "2.0"},
        "analysis_unit": {"const": "scenario"},
        "scenario_count": {"const": 384},
        "pair_table": {"$ref": "#/$defs/pairTable"},
        "statistics": {
          "type": "object",
          "additionalProperties": false,
          "required": ["delta", "exact_mcnemar_p", "bootstrap"],
          "properties": {
            "delta": {"type": "number", "minimum": -1, "maximum": 1},
            "exact_mcnemar_p": {"type": "number", "minimum": 0, "maximum": 1},
            "bootstrap": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "algorithm",
                "stratification",
                "resamples",
                "confidence",
                "lower",
                "upper",
                "binding_sha256",
                "samples_sha256"
              ],
              "properties": {
                "algorithm": {
                  "const": "stratified-paired-percentile-bootstrap-v1"
                },
                "stratification": {
                  "const": "scenario_type_x_provenance_pool"
                },
                "resamples": {"const": 10000},
                "confidence": {"const": 0.95},
                "lower": {"type": "number", "minimum": -1, "maximum": 1},
                "upper": {"type": "number", "minimum": -1, "maximum": 1},
                "binding_sha256": {"$ref": "#/$defs/sha256"},
                "samples_sha256": {"$ref": "#/$defs/sha256"}
              }
            }
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "required": ["B2", "C"],
          "properties": {
            "B2": {"type": "object"},
            "C": {"type": "object"}
          }
        },
        "pools": {
          "type": "object",
          "additionalProperties": false,
          "required": ["N", "A"],
          "properties": {
            "N": {"type": "object"},
            "A": {"type": "object"}
          }
        },
        "cells": {
          "type": "object",
          "minProperties": 16,
          "maxProperties": 16,
          "additionalProperties": {"type": "object"}
        }
      }
    },
    "live_qwen": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subset_count",
        "type_counts",
        "pool_counts",
        "required_runs",
        "minimum_passing_runs",
        "passing_runs",
        "run_gate_results",
        "actual_calls",
        "maximum_calls",
        "max_output_tokens",
        "timeout_seconds",
        "retry_limit",
        "model_id",
        "prompt_sha256",
        "shared_model_prompt_conditions",
        "answer_model_is_qwen",
        "oracle_uses_qwen",
        "judge_uses_qwen",
        "cost_authorization",
        "raw_responses_sha256",
        "usage_receipt_sha256"
      ],
      "properties": {
        "subset_count": {"const": 24},
        "type_counts": {
          "type": "object",
          "minProperties": 8,
          "maxProperties": 8,
          "additionalProperties": {"const": 3}
        },
        "pool_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["N", "A"],
          "properties": {
            "N": {"const": 12},
            "A": {"const": 12}
          }
        },
        "required_runs": {"const": 3},
        "minimum_passing_runs": {"const": 2},
        "passing_runs": {"type": "integer", "minimum": 0, "maximum": 3},
        "run_gate_results": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {"type": "boolean"}
        },
        "actual_calls": {"type": "integer", "minimum": 0, "maximum": 144},
        "maximum_calls": {"const": 144},
        "max_output_tokens": {"type": "integer", "minimum": 1, "maximum": 256},
        "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 30},
        "retry_limit": {"const": 0},
        "model_id": {"type": "string", "minLength": 1},
        "prompt_sha256": {"$ref": "#/$defs/sha256"},
        "shared_model_prompt_conditions": {"type": "boolean"},
        "answer_model_is_qwen": {"type": "boolean"},
        "oracle_uses_qwen": {"const": false},
        "judge_uses_qwen": {"const": false},
        "cost_authorization": {
          "enum": ["FREE_QUOTA_VERIFIED", "USER_APPROVED_PAID", "UNVERIFIED"]
        },
        "raw_responses_sha256": {"$ref": "#/$defs/sha256"},
        "usage_receipt_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_status",
        "promotion_status",
        "checks",
        "hold_findings",
        "kill_findings"
      ],
      "properties": {
        "gate_status": {
          "enum": [
            "PRIVATE_HOLDOUT_V2_PROMOTION_PASS",
            "PRIVATE_HOLDOUT_V2_KILL",
            "PRIVATE_HOLDOUT_V2_HOLD",
            "NOT_ELIGIBLE_EXTERNAL_INDEPENDENCE_UNPROVEN"
          ]
        },
        "promotion_status": {
          "enum": ["PROMOTE", "KILL", "HOLD", "NOT_ELIGIBLE"]
        },
        "checks": {
          "type": "object",
          "additionalProperties": {"type": "boolean"}
        },
        "hold_findings": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "kill_findings": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": {"const": "rsa-pkcs1v15-sha256"},
        "value": {"type": "string", "contentEncoding": "base64", "minLength": 1}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "gitSha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "pairTable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "both_success",
        "candidate_only",
        "baseline_only",
        "both_fail"
      ],
      "properties": {
        "both_success": {"type": "integer", "minimum": 0},
        "candidate_only": {"type": "integer", "minimum": 0},
        "baseline_only": {"type": "integer", "minimum": 0},
        "both_fail": {"type": "integer", "minimum": 0}
      }
    }
  }
}
